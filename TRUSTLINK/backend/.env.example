# ===== Server =====
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://192.168.0.4:5174

# ===== PostgreSQL (Amazon RDS) =====
# Set USE_PG=false to fall back to in-memory storage (good for local demo)
USE_PG=false
PGHOST=your-rds-endpoint.rds.amazonaws.com
PGPORT=5432
PGDATABASE=trustlink
PGUSER=trustlink_admin
PGPASSWORD=changeme
PGSSL=true

# ===== Amazon Neptune =====
# Set USE_NEPTUNE=false to fall back to in-memory graph adapter
USE_NEPTUNE=false
NEPTUNE_ENDPOINT=wss://your-neptune-endpoint.neptune.amazonaws.com:8182/gremlin
